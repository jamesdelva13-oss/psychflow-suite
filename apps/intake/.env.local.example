# Copy to .env.local and fill with values from your Supabase project.
# .env.local is gitignored — the service_role key must never be committed
# and must never be exposed to the browser (no NEXT_PUBLIC_ prefix).

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Full DB access, bypasses RLS. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Base URL used to build invitation links (dev default below).
APP_BASE_URL=http://localhost:3000
